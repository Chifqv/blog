@{
    User profileUser = new User("Eli", "eli@mail.ru", "00");
    List<Post> posts = new List<Post>() {
            new Post("hi!","https://avatars.mds.yandex.net/i?id=ee144099594ad4bd83755a6a556ba3a4_l-5088988-images-thumbs&n=13",profileUser),
            new Post("hi!","https://avatars.mds.yandex.net/i?id=ee144099594ad4bd83755a6a556ba3a4_l-5088988-images-thumbs&n=13",profileUser),
            new Post("hi!","https://avatars.mds.yandex.net/i?id=ee144099594ad4bd83755a6a556ba3a4_l-5088988-images-thumbs&n=13",profileUser)
            };

    ViewData["Title"] = $"{profileUser.Name} • Профиль";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="/css/Profile.css" />
</head>
<body>
    <div class="main-container">
        <div class="profile-info">
            <div class="profile-avatar">
                <img class="profile-avatar-img" src="/images/baseUser.jpg" />
            </div>

            <div class="profile-details">

                <div class="profile-stats">
                    <div class="stat"><span class="stat-number">@posts.Count</span> публикаций</div>
                    <div class="stat"><span class="stat-number">0</span> подписчиков</div>
                    <div class="stat"><span class="stat-number">0</span> подписок</div>
                </div>

                <div class="profile-bio">
                    <div class="bio-name">@profileUser.Name</div>
                    <div class="bio-email">@profileUser.Email</div>
                </div>
            </div>
        </div>

        <div class="profile-tabs">
            <button class="tab active" onclick="showTab('posts')">
                ПУБЛИКАЦИИ
            </button>
            <button class="tab" onclick="showTab('saved')">
                СОХРАНЕННЫЕ
            </button>
        </div>

        <div id="postsTab" class="posts-grid">
          
                @foreach (var post in posts)
                {
                    <div class="post-item" onclick="alert('Пост: @post.Description')">
                        @if (!string.IsNullOrEmpty(post.ImagePath))
                        {
                            <img src="@post.ImagePath" alt="Пост" />
                        }
                        else
                        {
                            <div style="width:100%; height:100%; background: linear-gradient(135deg, #667eea, #764ba2); display: flex; align-items: center; justify-content: center; color: white; font-size: 32px;">
                                📷
                            </div>
                        }
                    </div>
                }
            
        </div>

        <div id="savedTab" class="posts-grid" style="display: none;">
            <div class="empty-posts" style="grid-column: 1/-1;">
                <h3>🔖 Сохраненные публикации</h3>
                <p>Здесь будут сохраненные посты</p>
            </div>
        </div>
    </div>

</body>
</html>